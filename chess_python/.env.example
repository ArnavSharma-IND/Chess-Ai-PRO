# ChessAI Pro - Local Configuration Parameters
# Rename to '.env' before booting ChessAI Pro.

# STOCKFISH_PATH: Optional local Stockfish executable path to enable Expert AI engines.
STOCKFISH_PATH=

# DATABASE_PATH: Secure SQLite path relative to python project folder.
DATABASE_PATH=database/chess.db

# LOG_LEVEL: Sets application stdout verbosity threshold: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
